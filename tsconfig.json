{
  "include": ["**/*.ts", "**/*.tsx", "vite.config.ts"],
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "fumadocs-mdx:collections/*": ["./.source/*"],
      "@/*": ["./src/*"]
    }
  },
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    "next-env.d.ts",
    "next.config.ts",
    "open-next.config.ts",
    "load-next-env.ts",
    "load-next-env-direct.ts",
    "auth.loader.ts",
    "src/app/**/*"
  ]
}
